# ─────────────────────────────────────────────────────────────────────────────
# HealthcareBackend · Environment Variables
# Copy this file to .env and fill in YOUR values.
# NEVER commit .env to Git (it's in .gitignore already).
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────────────────────
# Generate key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Or visit: https://djecrety.ir/
SECRET_KEY=django-insecure-REPLACE-THIS-WITH-STRONG-SECRET-KEY
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────

# ┌─────────────────────────────────────────────────────────┐
# │  OPTION A – Local PostgreSQL (Development)              │
# │  Install: https://www.postgresql.org/download/windows/  │
# │  Create DB: psql -U postgres -c "CREATE DATABASE healthcare_db;" │
# └─────────────────────────────────────────────────────────┘
DB_NAME=healthcare_db
DB_USER=postgres
DB_PASSWORD=your_local_postgres_password
DB_HOST=localhost
DB_PORT=5432
DB_SSL=False

# ┌─────────────────────────────────────────────────────────┐
# │  OPTION B – Neon.tech Free Cloud PostgreSQL             │
# │  Steps:                                                  │
# │  1. Go to https://neon.tech → Sign up (GitHub works)    │
# │  2. Click "New Project" → pick a region                  │
# │  3. Go to Connection Details → choose "Parameters only"  │
# │  4. Fill in the values below from those parameters       │
# │  5. Set DB_SSL=True (Neon REQUIRES SSL)                  │
# └─────────────────────────────────────────────────────────┘
# DB_NAME=neondb
# DB_USER=your_neon_user
# DB_PASSWORD=your_neon_password
# DB_HOST=ep-cool-forest-xxxxxx.us-east-2.aws.neon.tech
# DB_PORT=5432
# DB_SSL=True

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
